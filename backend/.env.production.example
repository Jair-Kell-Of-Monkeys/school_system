# .env.production.example
# Variables de entorno para Railway — copia este archivo como referencia
# y configura cada variable en el panel de Railway (no subas el .env real al repo)

# ─── Django ────────────────────────────────────────────────────────────────────
SECRET_KEY=cambia-esto-por-una-clave-secreta-larga-y-aleatoria
DEBUG=False

# Hosts permitidos: el dominio de Railway + cualquier dominio propio (sin http://)
# Ejemplo: mi-backend.up.railway.app,api.miuniversidad.edu.mx
ALLOWED_HOSTS=mi-backend.up.railway.app

# ─── Base de datos ─────────────────────────────────────────────────────────────
# Railway la provee automáticamente si usas el plugin PostgreSQL.
# Cópiala desde la sección "Variables" del servicio de base de datos.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── CORS ──────────────────────────────────────────────────────────────────────
# Origen del frontend en Vercel (con https://)
# Ejemplo: https://mi-frontend.vercel.app,https://miuniversidad.edu.mx
CORS_ALLOWED_ORIGINS=https://mi-frontend.vercel.app

# ─── Email (Gmail SMTP) ────────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=correo@gmail.com
EMAIL_HOST_PASSWORD=app-password-de-gmail
DEFAULT_FROM_EMAIL=noreply@universidad.edu.mx

# ─── Celery / Redis ────────────────────────────────────────────────────────────
# Railway Redis plugin provee REDIS_URL automáticamente.
CELERY_BROKER_URL=redis://default:password@host:6379/0
CELERY_RESULT_BACKEND=redis://default:password@host:6379/0

# ─── URLs ──────────────────────────────────────────────────────────────────────
FRONTEND_URL=https://mi-frontend.vercel.app
INSTITUTIONAL_EMAIL_DOMAIN=universidad.edu.mx

# ─── Railway (no cambiar) ──────────────────────────────────────────────────────
# Railway define esta variable automáticamente; activa los settings de producción.
RAILWAY_ENVIRONMENT=production
