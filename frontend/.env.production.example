# .env.production.example
# Variables de entorno para Vercel — configura estas en el panel de Vercel
# (Settings → Environment Variables) o en un archivo .env.production local.

# URL base del backend en Railway (sin barra final)
# Ejemplo: https://mi-backend.up.railway.app/api
VITE_API_URL=https://mi-backend.up.railway.app/api
